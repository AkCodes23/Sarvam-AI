# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Sarvam dashboard -> API keys (https://dashboard.sarvam.ai)
SARVAM_API_KEY=

# HuggingFace write token (https://huggingface.co/settings/tokens)
HF_TOKEN=

# Your HF username or org (used to build the dataset repo id if HF_DATASET_REPO unset)
HF_USERNAME=

# Full dataset repo id to publish to, e.g. "your-username/sarvam-tts-in-te-en"
HF_DATASET_REPO=
